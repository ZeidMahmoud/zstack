#!/usr/bin/env bash
# zstack-review-read — read review log and config for dashboard
# Usage: zstack-review-read
set -euo pipefail
SCRIPT_DIR="$(cd "$(dirname "$0")" && pwd)"
eval "$("$SCRIPT_DIR/zstack-slug" 2>/dev/null)"
ZSTACK_HOME="${ZSTACK_HOME:-$HOME/.zstack}"
cat "$ZSTACK_HOME/projects/$SLUG/$BRANCH-reviews.jsonl" 2>/dev/null || echo "NO_REVIEWS"
echo "---CONFIG---"
"$SCRIPT_DIR/zstack-config" get skip_eng_review 2>/dev/null || echo "false"
echo "---HEAD---"
git rev-parse --short HEAD 2>/dev/null || echo "unknown"
